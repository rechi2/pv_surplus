# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Blueprint: Wallbox Phasenumschaltung 1→3                                 ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

blueprint:
  name: "Wallbox – Umschaltung 3-phasig"
  description: >
    Schaltet auf 3-phasig wenn der Ziel-Überschuss den Schwellwert
    für die eingestellte Dauer überschreitet.
  domain: automation

  input:
    wallbox_frc_entity:
      name: "Wallbox Force-State (frc)"
      selector:
        entity:
          filter:
            - domain: select

    wallbox_psm_entity:
      name: "Wallbox Phasenmodus (psm)"
      selector:
        entity:
          filter:
            - domain: select

    surplus_sensor:
      name: "Ziel-Überschuss Sensor"
      description: "sensor.wallbox_ziel_ueberschuss oder eigener Sensor."
      selector:
        entity:
          filter:
            - domain: sensor
              device_class: power

    lademodus_entity:
      name: "Lademodus"
      selector:
        entity:
          filter:
            - domain: input_select

    threshold_phase_up:
      name: "Schwellwert Phase-Up (W)"
      description: "Überschuss ab dem auf 3-phasig geschaltet wird."
      default: 4800
      selector:
        number:
          min: 3500
          max: 8000
          step: 100
          unit_of_measurement: "W"

    phase_up_duration:
      name: "Wartezeit (Minuten)"
      description: "Wie lange der Schwellwert überschritten sein muss."
      default: 5
      selector:
        number:
          min: 1
          max: 15
          step: 1
          unit_of_measurement: "min"

mode: queued
max: 10

trigger:
  - platform: numeric_state
    entity_id: !input surplus_sensor
    above: !input threshold_phase_up
    for:
      minutes: !input phase_up_duration

condition:
  - condition: state
    entity_id: !input lademodus_entity
    state: "PV-Überschuss"
  - condition: state
    entity_id: !input wallbox_psm_entity
    state: "1"

action:
  - service: select.select_option
    target:
      entity_id: !input wallbox_frc_entity
    data:
      option: "1"
  - delay:
      seconds: 5
  - service: select.select_option
    target:
      entity_id: !input wallbox_psm_entity
    data:
      option: "2"
  - delay:
      seconds: 5
  - service: select.select_option
    target:
      entity_id: !input wallbox_frc_entity
    data:
      option: "2"
